# ════════════════════════════════════════════════════════════════════════════
# DisruptIQ V2 — PRODUCTION Environment Variables
# Set ALL of these in your hosting platform's secrets/env manager.
# NEVER commit this file with real values.
# ════════════════════════════════════════════════════════════════════════════

# ─── CRITICAL: Generate a new secret ─────────────────────────────────────
# Run: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=GENERATE_A_NEW_32_BYTE_HEX_STRING

# ─── Demo Mode OFF for production ────────────────────────────────────────
DEMO_MODE=false

# ─── GitHub Models API (LLM) ─────────────────────────────────────────────
# Create a new PAT: https://github.com/settings/tokens (grant 'models:read')
GITHUB_TOKEN=ghp_YOUR_NEW_TOKEN
GITHUB_MODELS_ENDPOINT=https://models.inference.ai.azure.com
GITHUB_MODEL=gpt-4o

# ─── Azure Cosmos DB ─────────────────────────────────────────────────────
# Regenerate keys in Azure Portal after revoking the old ones
AZURE_COSMOS_ENDPOINT=https://your-cosmos.documents.azure.com:443/
AZURE_COSMOS_KEY=YOUR_NEW_COSMOS_KEY
AZURE_COSMOS_DATABASE=disruptiq
AZURE_COSMOS_CONTAINER_MEMORY=swarm_memory
AZURE_COSMOS_CONTAINER_AUDIT=audit_log
AZURE_COSMOS_CONTAINER_EVENTS=events

# ─── Azure Content Safety ────────────────────────────────────────────────
AZURE_CONTENT_SAFETY_ENDPOINT=https://your-safety.cognitiveservices.azure.com/
AZURE_CONTENT_SAFETY_KEY=YOUR_NEW_SAFETY_KEY

# ─── Email (Gmail SMTP) ──────────────────────────────────────────────────
EMAIL_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=your_new_gmail_app_password
SMTP_FROM_NAME=DisruptIQ Platform
SMTP_FROM_EMAIL=your-gmail@gmail.com

# ─── App URLs — MUST match your real domain ──────────────────────────────
APP_BASE_URL=https://disruptiqai.com
FRONTEND_URL=https://disruptiqai.com

# ─── Admin access ────────────────────────────────────────────────────────
ADMIN_EMAILS=bharathkumarkcs99@gmail.com

# ─── CORS — your frontend domain ─────────────────────────────────────────
CORS_ORIGINS=https://disruptiqai.com,https://www.disruptiqai.com

# ─── News feed ───────────────────────────────────────────────────────────
NEWSAPI_KEY=YOUR_NEWSAPI_KEY

# ─── Server ──────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ─── Operational tuning (safe defaults) ──────────────────────────────────
SEVERITY_THRESHOLD=6
DISSENT_DIVERGENCE_THRESHOLD=30
CASCADE_WINDOW_HOURS=48
CASCADE_OVERLAP_MULTIPLIER=1.2
SIMULATION_SLA_SECONDS=30
MAX_VALIDATOR_RERUNS=2
MEMORY_RETENTION_MONTHS=36
