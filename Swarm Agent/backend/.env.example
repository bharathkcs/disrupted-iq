# DisruptIQ V2 — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to version control.

# ── Deployment mode ──────────────────────────────────────────────
# true ONLY for local dev without credentials (ephemeral in-memory storage,
# synthetic LLM output). MUST be false for any real deployment.
DEMO_MODE=false

# ── Security (REQUIRED in production) ────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Startup is BLOCKED if this is left at the default while DEMO_MODE=false.
JWT_SECRET=REPLACE_WITH_GENERATED_32_BYTE_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24
JWT_REMEMBER_ME_DAYS=30

# ── LLM (GitHub Models) ──────────────────────────────────────────
GITHUB_TOKEN=
GITHUB_MODELS_ENDPOINT=https://models.inference.ai.azure.com
GITHUB_MODEL=gpt-4o

# ── Azure Cosmos DB (required when DEMO_MODE=false) ──────────────
AZURE_COSMOS_ENDPOINT=
AZURE_COSMOS_KEY=
AZURE_COSMOS_DATABASE=disruptiq

# ── Azure Content Safety (optional) ──────────────────────────────
AZURE_CONTENT_SAFETY_ENDPOINT=
AZURE_CONTENT_SAFETY_KEY=

# ── Application Insights (optional) ──────────────────────────────
APPLICATIONINSIGHTS_CONNECTION_STRING=

# ── External feeds ───────────────────────────────────────────────
NEWSAPI_KEY=

# ── Email (set EMAIL_ENABLED=true to actually send) ──────────────
EMAIL_ENABLED=false
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@disruptiq.dev
SENDGRID_FROM_NAME=DisruptIQ Platform
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# ── App URLs ─────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
SUPPORT_EMAIL=kcsbadp@gmail.com

# ── Server ───────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
# Comma-separated allow-list. localhost:3000-3010 are auto-added only in DEMO_MODE.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Operational tuning ───────────────────────────────────────────
SEVERITY_THRESHOLD=6
DISSENT_DIVERGENCE_THRESHOLD=30
CASCADE_WINDOW_HOURS=48
CASCADE_OVERLAP_MULTIPLIER=1.2
SIMULATION_SLA_SECONDS=30
MINIMUM_SEVERITY_TO_ALERT=6

# ── Limits ───────────────────────────────────────────────────────
API_RATE_LIMIT_PER_MINUTE=100
FREE_TIER_DAILY_SWARM_LIMIT=25
